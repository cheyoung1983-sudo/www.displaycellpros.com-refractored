# ============================================================================
# DISPLAY & CELL PROS DIAGNOSTIC HUB - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# This file documents all required/optional environment variables for the
# structural forensics and neural RAG system. Fill in these keys on your local 
# development environments or inside your remote Cloud Run runtime properties.
# Do NOT check-in raw production credentials, tokens, or security certificates.

# -----------------
# 1. NODE ENVIRONMENT CONFIGURATION
# -----------------
# NODE_ENV: Defines the runtime context ('development', 'production', or 'test')
NODE_ENV="development"

# -----------------
# 2. NEURAL COMPILATION & AI REASONING
# -----------------
# GEMINI_API_KEY: Required for genuine multi-turn Gemini reasoning and computer-vision audits.
# Injected automatically in the AI Studio preview, or configured in external hosting platforms.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# -----------------
# 3. SELF-REFERENTIAL & WEB SERVICE PARAMS
# -----------------
# APP_URL: The public-facing HTTP address where this service is hosted.
# Used for constructing secure redirect domains and validating CORS.
APP_URL="http://localhost:3000"

# -----------------
# 4. SOVEREIGN CLOUD SQL POSTGRESQL CONNECTORS
# -----------------
# Host address/socket path for the relational database node.
SQL_HOST="localhost"

# Standard non-root database credentials.
SQL_USER="postgres"
SQL_PASSWORD="password"
SQL_DB_NAME="triage_db"

# Admin-tier credentials used exclusively for DDL migration scripts and schema definitions.
SQL_ADMIN_USER="postgres"
SQL_ADMIN_PASSWORD="password"

# -----------------
# 5. CRYPTOGRAPHIC ACCESS CONTROL & SECURE KEYS
# -----------------
# AES-256-CBC encryption seed wrapper used to seal and guard OAuth credentials inside the SQL schemas.
# Must be a cryptographically sound, unique hex-key (32 bytes / 64 hexadecimal characters).
OAUTH_ENCRYPTION_KEY="8f7ab2d6e3c091f1b2c45e6f7a8b9c0d1e2f3a4b5c6d7e8f9a0b1c2d3e4f5a6b"

# -----------------
# 6. GOOGLE RECAPTCHA ENTERPRISE CONFIGURATION
# -----------------
# VITE_RECAPTCHA_SITE_KEY: The public score-based site key used on the frontend to render the script and execute challenges.
VITE_RECAPTCHA_SITE_KEY="6LcgWy4tAAAAABP-_hU5ngbkKF5scb2DnI2_bscl"
# RECAPTCHA_PROJECT_ID: The Google Cloud project ID containing your reCAPTCHA Enterprise key.
RECAPTCHA_PROJECT_ID="displaycellpros-com"

# -----------------
# 7. FIREBASE CONFIGURATION (VITE_ PREFIX REQUIRED FOR FRONTEND)
# -----------------
VITE_FIREBASE_API_KEY="YOUR_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="displaycellpros-com.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="displaycellpros-com"
VITE_FIREBASE_STORAGE_BUCKET="displaycellpros-com.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="YOUR_SENDER_ID"
VITE_FIREBASE_APP_ID="YOUR_APP_ID"
VITE_FIREBASE_MEASUREMENT_ID="YOUR_MEASUREMENT_ID"
FIREBASE_ADMIN_KEY='{"type": "service_account", ...}'

# -----------------
# 8. AUTH0 MCP SERVER — FORENSIC IDENTITY MANAGEMENT BRIDGE
# -----------------
# Required for the Auth0 MCP Server integration and the /api/auth0/* REST gateway.
#
# AUTH0_DOMAIN: Your Auth0 tenant domain (no https:// prefix).
# Example: displaycellpros.us.auth0.com
AUTH0_DOMAIN="your-tenant.us.auth0.com"

# AUTH0_CLIENT_ID / AUTH0_CLIENT_SECRET:
# Credentials for a Machine-to-Machine application registered in your Auth0 tenant.
# This app must be authorized to access the Auth0 Management API with at minimum:
#   read:clients, update:clients, create:clients
#   read:resource_servers, update:resource_servers, create:resource_servers
#   read:actions, update:actions, create:actions, deploy:actions
#   read:logs
#   read:forms, update:forms, create:forms, publish:forms
AUTH0_CLIENT_ID="YOUR_AUTH0_M2M_CLIENT_ID"
AUTH0_CLIENT_SECRET="YOUR_AUTH0_M2M_CLIENT_SECRET"

# AUTH0_AUDIENCE (optional):
# Defaults to https://{AUTH0_DOMAIN}/api/v2/ — only override if using a custom audience.
# AUTH0_AUDIENCE="https://your-tenant.us.auth0.com/api/v2/"

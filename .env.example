# --- Core AI & API Configuration ---
# OPENAI_API_KEY: Required for OpenAI AI API calls (gpt-4o, o3-mini).
OPENAI_API_KEY="sk-..."

# APP_URL: The URL where this applet is hosted (e.g. https://www.displaycellpros.com)
APP_URL="http://localhost:3000"

# --- Firebase Client Config (Public) ---
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# --- Google reCAPTCHA Enterprise ---
VITE_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""
GOOGLE_CLOUD_PROJECT_ID=""

# --- AWS RDS PostgreSQL Configuration ---
PGHOST=""
PGUSER=""
PGDATABASE="postgres"
PGPORT="5432"
PGSSLMODE="require"
PGPASSWORD=""

# --- AWS IAM OIDC Connectivity (Vercel) ---
AWS_REGION="us-east-1"
AWS_ROLE_ARN="arn:aws:iam::..."
AWS_ACCOUNT_ID=""

# --- Vercel Edge Config (Optional) ---
# Used for remote configuration and flags
EDGE_CONFIG=""

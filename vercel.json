{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.ts"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      },
      "src": "/(.*).(png|jpg|jpeg|gif|svg|ico|webp|woff|woff2|ttf|otf)",
      "dest": "/$1.$2"
    },
    {
      "headers": {
        "cache-control": "no-store, must-revalidate"
      },
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}

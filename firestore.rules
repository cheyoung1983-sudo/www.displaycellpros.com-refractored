rules_version = '2';

/**
 * ⚖️ SILICON FORENSIC SECURITY AUDIT PROTOCOL (CoV Framework)
 * Project: Display Cell Pros Triage-AI
 * Standards: NIST SP 800-88 R1 compliant access controls
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isForensicInvestigator() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'forensic_investigator';
    }

    // --- COLLECTION RULES ---

    // 1. User Profiles & Forensic Credentials
    match /users/{userId} {
      allow read: if isOwner(userId) || isForensicInvestigator();
      allow write: if isOwner(userId);
    }

    // 2. CoV Protected: Diagnostic Sessions (S2C Mapping Data)
    match /diagnostic_sessions/{sessionId} {
      // Access requires verified Identity Gateway login and investigator role
      allow read: if isForensicInvestigator();

      // DTF Writing: Enforce NIST SP 800-88 R1 and Thermal Safety fields
      allow create: if isSignedIn() &&
                    request.resource.data.telemetry_sensors.is_thermal_runaway_risk != null;

      allow update: if isForensicInvestigator();
    }

    // 3. Legacy Forensic Triage Tickets (S2C Mapping Data)
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isForensicInvestigator());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isForensicInvestigator());
      allow delete: if isForensicInvestigator();
    }

    // 4. Inbound Service Leads
    match /leads/{leadId} {
      allow create: if true; // Public lead generation
      allow read, update, delete: if isForensicInvestigator();
    }

    // 5. Forensic Feedback & Audit Logs
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isForensicInvestigator();
    }

    // --- GLOBAL SECURITY FIREWALL ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';

/**
 * ⚖️ SILICON FORENSIC SECURITY AUDIT PROTOCOL
 * Project: Display Cell Pros Triage-AI
 * Standards: NIST SP 800-88 R1 compliant access controls
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: Verify user authentication state
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: Verify document ownership
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Helper: Verify forensic investigator role (Admin)
    function isForensicInvestigator() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'forensic_investigator';
    }

    // --- COLLECTION RULES ---

    // User profiles & forensic credentials
    match /users/{userId} {
      allow read: if isOwner(userId) || isForensicInvestigator();
      allow write: if isOwner(userId);
    }

    // Forensic Triage Tickets (S2C Mapping Data)
    match /tickets/{ticketId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isForensicInvestigator());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (resource.data.userId == request.auth.uid || isForensicInvestigator());
      allow delete: if isForensicInvestigator();
    }

    // Inbound Service Leads
    match /leads/{leadId} {
      allow create: if true; // Public lead generation
      allow read, update, delete: if isForensicInvestigator();
    }

    // Forensic Feedback & Audit Logs
    match /feedback/{feedbackId} {
      allow create: if isSignedIn();
      allow read: if isForensicInvestigator();
    }

    // Global Catch-all (Explicit Deny)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

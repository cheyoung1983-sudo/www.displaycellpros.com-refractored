rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
             (request.auth.token.email == 'cheyoung1983@gmail.com' && request.auth.token.email_verified == true);
    }

    // User Profiles: Users can read/write their own profile
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Repair Tickets: Users can read their own tickets. Admin can read/write all.
    match /tickets/{ticketId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // High Priority Leads: Users can create/read their own. Admin can read/write all.
    match /high-priority-leads/{leadId} {
      allow read: if isAdmin() || (isAuthenticated() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // S2C Feedback: Users can create feedback. Admin can read all.
    match /s2c-feedback/{feedbackId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read: if isAdmin();
    }

    // Session Drafts: Users can read/write their own drafts.
    match /drafts/{draftId} {
      allow read, write: if isAuthenticated() &&
        (resource == null || resource.data.userId == request.auth.uid) &&
        (request.method == 'DELETE' || request.resource.data.userId == request.auth.uid);
    }

    // POS Logs: Admin only (typically written by backend admin SDK)
    match /pos-logs/{logId} {
      allow read, write: if isAdmin();
    }

    // reCAPTCHA Assessments: Admin only.
    match /recaptcha-assessments/{assessmentId} {
      allow read, write: if isAdmin();
    }

    // Security Audits: Admin only.
    match /SecurityAudits/{auditId} {
      allow read, write: if isAdmin();
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=22.x"
  },
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "sitemap": "tsx scripts/generate-sitemap.ts",
    "postbuild": "npm run sitemap"
  },
  "dependencies": {
    "@aws-sdk/rds-signer": "^3.1089.0",
    "@google-cloud/recaptcha-enterprise": "^6.4.2",
    "@tailwindcss/vite": "^4.1.14",
    "@vercel/edge": "^1.2.0",
    "@vercel/edge-config": "^1.4.3",
    "@vercel/functions": "^3.7.5",
    "@vercel/node": "^5.1.0",
    "@vercel/oidc-aws-credentials-provider": "^3.3.0",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "ai": "^4.1.45",
    "compression": "^1.8.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "firebase": "^11.1.0",
    "helmet": "^8.0.0",
    "jspdf": "^4.2.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "recharts": "^3.8.1",
    "stream-chat": "^8.57.0"
  },
  "devDependencies": {
    "@ai-sdk/openai": "^1.1.15",
    "@types/compression": "^1.7.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.21",
    "dotenv-expand": "^13.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
